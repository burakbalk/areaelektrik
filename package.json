{
  "name": "react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && react-snap && node scripts/postprocess.js",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit --project tsconfig.app.json"
  },
  "reactSnap": {
    "source": "out",
    "destination": "out",
    "fallback": "index.html",
    "include": [
      "/",
      "/hakkimizda",
      "/hizmetler",
      "/projeler",
      "/blog",
      "/iletisim"
    ],
    "puppeteerExecutablePath": "/Applications/Brave Browser.app/Contents/MacOS/Brave Browser",
    "puppeteerArgs": ["--no-sandbox", "--disable-setuid-sandbox"],
    "inlineCss": true,
    "minifyHtml": {
      "collapseWhitespace": true,
      "removeComments": true
    }
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jiti": "^2.6.1",
    "postcss": "^8.5.6",
    "react-snap": "^1.23.0",
    "source-map": "^0.7.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "unplugin-auto-import": "^19.3.0",
    "vite": "^7.0.3"
  }
}
